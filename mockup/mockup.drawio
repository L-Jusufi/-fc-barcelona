  <diagram name="Browser-Server-Interaktion" id="protoPage">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="titleP" value="Interaktion zwischen Browser und Webserver (HTTP/HTTPS)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="750" height="30" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="Browser&#10;(Client)&#10;Chrome / Firefox" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#004D98;strokeColor=#002B5C;fontColor=#FFFFFF;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="server" value="Webserver&#10;(Apache / Nginx)&#10;hostet HTML, CSS, Bilder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A50044;strokeColor=#5C0026;fontColor=#FFFFFF;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="170" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="req" value="1. HTTPS GET-Request&#10;GET /index.html" style="endArrow=classic;html=1;fontSize=12;strokeColor=#222222;strokeWidth=2;fontStyle=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="245" y="200" as="sourcePoint" />
            <mxPoint x="595" y="200" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="res" value="2. HTTP-Response&#10;HTML + CSS + Bilder" style="endArrow=classic;html=1;fontSize=12;strokeColor=#EDBB00;strokeWidth=2;fontStyle=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="595" y="250" as="sourcePoint" />
            <mxPoint x="245" y="250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step3" value="3. Browser rendert die Seite und zeigt sie dem Benutzer an." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="720" height="30" as="geometry" />
        </mxCell>
        <mxCell id="proto" value="Verwendete Protokolle:&#10;- HTTP / HTTPS (Port 80 / 443) - fuer die Webseiten-Kommunikation&#10;- TCP/IP - als Transportschicht&#10;- DNS - zur Aufloesung der Domain in eine IP-Adresse" style="text;html=1;strokeColor=#888888;fillColor=#F4F4F4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="720" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
